@namespace ElementalUtopia.Components.Hero

<section class="hero">

    <picture>
        <source srcset="/images/LightSmall.jpg" media="(prefers-color-scheme: light)">
        <img class="hero-logo" src="/images/DarkSmall.jpg" alt="Elemental Utopia" />
    </picture>

    <div class="hero-content">

        <h1>Elemental Utopia</h1>

        <p class="subtitle">
            Specialty Coffee • Coffee Science • Extraction Focus
        </p>

        <p>
            Elemental Utopia is a UK-based specialty coffee brand built around experimentation,
            flavour profiling, and a scientific approach to espresso and coffee extraction.
        </p>

        <div class="hero-buttons">
            <a class="btn primary" href="/logo">View Logo Story</a>
            <a class="btn primary" href="/menu">Explore Menu</a>
        </div>

    </div>

</section>